{
  "name": "@aggc/no-coauthor",
  "version": "2.3.0",
  "description": "Git hook that strips AI co-author trailers (Claude, Copilot, Codex, Cursor, Oz/Warp, GPT, Gemini, Devin, etc.) from commit messages while preserving human co-authors",
  "license": "MIT",
  "author": "0xdsgnrd",
  "contributors": [
    "jmtrs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmtrs/no-coAuthor.git"
  },
  "bin": {
    "no-coauthor": "bin/no-coauthor.js"
  },
  "files": [
    "bin/",
    "lib/",
    "install.sh",
    "examples/",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test",
    "prepublishOnly": "npm test",
    "sync-install-sh": "node scripts/sync-install-sh.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "git",
    "hooks",
    "commit-msg",
    "commit",
    "co-author",
    "co-authored-by",
    "ai",
    "claude",
    "claude-code",
    "copilot",
    "codex",
    "gpt",
    "chatgpt",
    "gemini",
    "cursor",
    "devin"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0"
  },
  "dependencies": {
    "picocolors": "1.1.1"
  }
}
